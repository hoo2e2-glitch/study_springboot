<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.restful.mapper.PostMapper">
    <!--parameterType = DB에 보낼 값 타입 / resultType = DB에서 받을 값 타입-->
    <!--조회는 받는값이 중요-->
    <!--RequestDTO : 클라이언트가 보낼 때-->
    <!--ResponseDTO : 서버가 응답으로 줄 때-->
    <!--등록/수정/삭제용: 보통 VO-->

    <!--//4. mapper.xml 정의-->
    <!--게시글 목록 조회 서비스-->
    <select id="selectAll" resultType="PostDTO" parameterType="Map">
        SELECT TBP.ID, TBP.POST_TITLE, TBP.POST_CONTENT, TBP.MEMBER_ID, TBP.POST_READ_COUNT,
               TBM.MEMBER_EMAIL, TBM.MEMBER_NAME
        FROM TBL_POST TBP
        JOIN TBL_MEMBER TBM
        ON TBP.MEMBER_ID = TBM.ID
        /* 동적 쿼리(최신순, 조회순) */
        <choose>
            <!-- 오래된 순 -->
            <when test="order.equals('oldest')">
                ORDER BY TBP.ID ASC
            </when>
            <!-- 조회순 -->
            <when test="order.equals('read')">
                ORDER BY TBP.POST_READ_COUNT DESC
            </when>
            <!-- 기본 최신순 -->
            <otherwise>
                ORDER BY TBP.ID DESC
            </otherwise>
        </choose>
    </select>

    <!--게시글 상세보기 조회 서비스-->
    <select id="selectById" parameterType="Long" resultType="PostDTO">
        SELECT TBP.ID, TBP.POST_TITLE, TBP.POST_CONTENT, TBP.MEMBER_ID, TBP.POST_READ_COUNT,
               TBM.MEMBER_EMAIL, TBM.MEMBER_NAME
        FROM TBL_POST TBP
        JOIN TBL_MEMBER TBM
        ON TBP.MEMBER_ID = TBM.ID /*AND TBP.ID = #{id}*/
        WHERE TBP.ID = #{id}
    </select>

    <!--게시글 작성 서비스-->
    <insert id="insert" parameterType="PostVO">
        <selectKey keyProperty="id" order="BEFORE" resultType="Long">
            SELECT SEQ_POST.NEXTVAL FROM DAUL
        </selectKey>
        INSERT INTO TBL_POST(ID, POST_TITLE, POST_CONTENT, MEMBER_ID)
        VALUES (#{id} #{postTitle}, #{postContent}, #{memberId})
    </insert>

    <!--게시글 수정 서비스-->
    <update id="update" parameterType="PostVO">
        UPDATE TBL_POST
        SET POST_TITLE = #{postTitle}, POST_CONTENT = #{postContent}
        WHERE ID = #{id}
    </update>

    <!--게시글 삭제 서비스-->
    <delete id="delete" parameterType="Long">
        DELETE FROM TBL_POST
        WHERE ID =  #{id}
    </delete>

    <!--게시글 삭제(탈퇴시) 서비스-->
    <delete id="deleteByMemberId" parameterType="Long">
        DELETE FROM TBL_POST
        WHERE MEMBER_ID =  #{memberId}
    </delete>




    <!--게시글 조회수 증가 서비스-->
