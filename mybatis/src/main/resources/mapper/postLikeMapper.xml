<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.mybatis.mapper.PostLikeMapper">

    <!-- 좋아요 추가 insert  -->
    <insert id="insert" parameterType="PostLikeVO">
        INSERT INTO TBl_POST_LIKE
        VALUES(SEQ_POST_LIKE.NEXTVAL, #{postId}, #{memberId})
    </insert>

    <!-- 좋아요 취소 delete  -->
    <delete id="deleteWithPostLike" parameterType="Long">
        DELETE FROM TBL_POST_LIKE
        WHERE ID = #{id}
    </delete>






</mapper>